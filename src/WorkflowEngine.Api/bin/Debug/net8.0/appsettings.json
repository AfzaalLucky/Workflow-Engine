{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "WorkflowEngineDb": "Server=.;Database=WorkflowEngineDb;Trusted_Connection=True;TrustServerCertificate=True;"
  },
  "Jwt": {
    "Issuer": "WorkflowEngine",
    "Audience": "WorkflowEngineClients",
    "SigningKey": "dev-only-signing-key-replace-with-a-real-secret-before-any-shared-deployment-32chars+",
    "ExpiryMinutes": 480
  }
}
